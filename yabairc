#!/usr/bin/env sh
# Requires: yabai, skhd, jankyborders
# See .skhdrc for keybindings

# Layout
yabai -m config layout bsp

# Master area ratio (dwm mfact = 0.55)
yabai -m config split_ratio 0.45
yabai -m config auto_balance off
yabai -m config window_placement second_child

# Gaps
# yabai inner gaps are between windows; outer gaps are window↔screen edge
yabai -m config window_gap          24   # inner vertical  (gappiv)
yabai -m config top_padding         30   # outer vertical  (gappov)
yabai -m config bottom_padding      30   # outer vertical  (gappov)
yabai -m config left_padding        20   # outer horizontal(gappoh)
yabai -m config right_padding       20   # outer horizontal(gappoh)
# Note: yabai has a single window_gap; we use gappiv (24) as the base.
# The extra horizontal inner gap (gappih=40) is approximated via padding.

# Borders
# Requires: JankyBorders (https://github.com/FelixKratz/JankyBorders)
# If you're not using JankyBorders, remove the border lines below.
borders active_color=0xffe584f0 inactive_color=0xff415066 width=5.0 &

# ── Focus behaviour ───────────────────────────────────────────────────────────
# Follow mouse focus (similar to dwm's click-to-focus default)
yabai -m config focus_follows_mouse  autofocus
yabai -m config mouse_follows_focus  off

# ── Mouse actions ─────────────────────────────────────────────────────────────
yabai -m config mouse_modifier       cmd          # MODKEY = Super/Mod4 → cmd on macOS
yabai -m config mouse_action1        move         # cmd + left-drag  → movemouse
yabai -m config mouse_action2        resize       # cmd + right-drag → resizemouse
yabai -m config mouse_drop_action    swap

# ── Window rules ──────────────────────────────────────────────────────────────
yabai -m rule --add app="Firefox" title="Picture-in-Picture"  manage=off
yabai -m rule --add app="System Preferences"    manage=off
yabai -m rule --add app="System Settings"       manage=off
yabai -m rule --add app="Calculator"            manage=off
yabai -m rule --add app="Archive Utility"       manage=off
yabai -m rule --add app="java"  manage=off
yabai -m rule --add app="Finder"  manage=off
yabai -m rule --add app="Clock"  manage=off
yabai -m rule --add app="Scene Builder"  manage=off
yabai -m rule --add app="^Anki$" title="Add"  manage=off
yabai -m rule --add app="^Anki$" title="Browse"  manage=off

# ── Signals ───────────────────────────────────────────────────────────────────
# Reload sketchybar / polybar equivalent on space/window changes
# (uncomment if you use sketchybar)
# yabai -m signal --add event=window_focused   action="sketchybar --trigger window_focus"
# yabai -m signal --add event=space_changed    action="sketchybar --trigger space_change"

echo "yabai config loaded"
