[core]
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection

[merge]
    conflictStyle = zdiff3

[user]
  name = Ethan Ng
  email = ethan@turbocharged.ca

[gpg]
  format = ssh

[commit]
  gpgsign = true

[tag]
  gpgsign = true

[pull]
  rebase = true

[init]
  defaultBranch = main

[diff]
  algorithm = histogram
  colorMoved = default

[merge]
  conflictstyle = diff3

[color]
  ui = auto
